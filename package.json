	"public": true,
	"main": "./dist/index.js",
	"typings": "./dist/index.d.ts",
	"scripts": {
		"test": "cross-env COVERAGE=full jest --coverage",
		"test:ci": "cross-env COVERAGE=full jest --ci --coverage --maxWorkers=50% --reporters=default --reporters=jest-junit",
		"test:fast": "cross-env COVERAGE=summary jest --bail --coverage",
		"lint": "pnpm lint:nofix",
		"lint:nofix": "pnpm eslint src/**.{js,ts} --quiet",
		"lint:fix": "pnpm eslint src/**/*.{js,ts,tsx} --quiet --fix",
		"build": "pnpm lint && pnpm gulp",
		"make:docs": "pnpm typedoc docs --categorizeByGroup false --entryPoints ./src/index.ts"
	},
